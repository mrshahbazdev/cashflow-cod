// Cashflow COD — Prisma schema v1
// https://www.prisma.io/docs
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Shopify session storage (required by @shopify/shopify-app-session-storage-prisma)
// -----------------------------------------------------------------------------
model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)

  @@index([shop])
}

// -----------------------------------------------------------------------------
// Core app models
// -----------------------------------------------------------------------------
model Shop {
  id            String    @id @default(cuid())
  domain        String    @unique
  plan          Plan      @default(FREE)
  settings      Json      @default("{}")
  timezone      String    @default("UTC")
  installedAt   DateTime  @default(now())
  uninstalledAt DateTime?
  updatedAt     DateTime  @updatedAt

  merchantGroupId String?
  merchantGroup   MerchantGroup? @relation(fields: [merchantGroupId], references: [id], onDelete: SetNull)

  fraudGraphOptIn Boolean @default(false)

  defaultLanguage String  @default("en")
  enabledLanguages Json   @default("[\"en\"]")

  forms           Form[]
  orders          Order[]
  blocklist       Blocklist[]
  agents          Agent[]
  pixels          Pixel[]
  webhooks        WebhookSubscription[]
  abTests         ABTest[]
  courierAccounts CourierAccount[]
  rtoStats        RtoStat[]
  fraudReports    FraudGraphReport[]
  inboxThreads    InboxThread[]
  landingPages    LandingPage[]
  paymentAccounts PaymentProviderAccount[]
  gdprExports     GdprExport[]
  integrations    Integration[]
  webhookDeliveries WebhookDelivery[]
  discounts       Discount[]
  quantityOffers  QuantityOffer[]
  discountRedemptions DiscountRedemption[]

  @@index([domain])
  @@index([merchantGroupId])
}

enum Plan {
  FREE
  STARTER
  PRO
  SCALE
  ENTERPRISE
}

model Form {
  id        String     @id @default(cuid())
  shopId    String
  shop      Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  layout    FormLayout @default(POPUP)
  placement String     @default("product") // product | cart | landing | custom
  schema    Json       @default("{}") // form field definitions (Zod-validated JSON)
  translations Json    @default("{}") // { "ur": {"label.phone": "..."}, ... }
  direction String     @default("ltr") // ltr | rtl
  isActive  Boolean    @default(true)
  abTestId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  submissions   Submission[]
  orders        Order[]
  views         FormView[]
  upsells       Upsell[]
  abandoned     AbandonedForm[]
  landingPages  LandingPage[]

  @@unique([shopId, slug])
  @@index([shopId])
}

enum FormLayout {
  POPUP
  EMBEDDED
  SLIDEOVER
  LANDING
}

model FormView {
  id        String   @id @default(cuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  visitorId String
  ip        String?
  userAgent String?
  country   String?
  referrer  String?
  createdAt DateTime @default(now())

  @@index([formId, createdAt])
}

model Submission {
  id              String           @id @default(cuid())
  formId          String
  form            Form             @relation(fields: [formId], references: [id], onDelete: Cascade)
  visitorId       String
  status          SubmissionStatus @default(PENDING)
  fields          Json             @default("{}")
  fieldsEncrypted Bytes?
  phone           String?
  email           String?
  ipAddress       String?
  userAgent       String?
  country         String?
  riskScore       Int?
  riskReasons     Json             @default("[]")
  requiresOtp     Boolean          @default(false)
  abVariant       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  order     Order?
  otpTokens OtpToken[]

  @@index([formId, createdAt])
  @@index([status])
}

enum SubmissionStatus {
  PENDING
  VERIFIED
  REJECTED
  CONVERTED
  ABANDONED
}

model Order {
  id              String      @id @default(cuid())
  shopId          String
  shop            Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopifyOrderId  String?     @unique
  shopifyOrderGid String?
  submissionId    String?     @unique
  submission      Submission? @relation(fields: [submissionId], references: [id])
  formId          String?
  form            Form?       @relation(fields: [formId], references: [id])
  phone           String?
  phoneNormalized String?
  email           String?
  customerName    String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  region          String?
  postalCode      String?
  country         String?
  lineItems       Json        @default("[]")
  upsells         Json        @default("[]")
  subtotal        Decimal?    @db.Decimal(14, 2)
  codFee          Decimal?    @db.Decimal(14, 2)
  discount        Decimal?    @db.Decimal(14, 2)
  total           Decimal?    @db.Decimal(14, 2)
  currency        String?
  riskScore       Int?
  riskReasons     Json        @default("[]")
  disposition     Disposition @default(UNASSIGNED)
  agentId         String?
  agent           Agent?      @relation(fields: [agentId], references: [id])
  attempts        Int         @default(0)
  nextFollowUpAt  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  otps            OtpToken[]
  messages        Message[]
  agentActions    AgentAction[]
  courierBookings CourierBooking[]
  callSessions    CallSession[]
  riskEvaluations RiskEvaluation[]
  paymentAdvances PaymentAdvance[]
  inboxThread     InboxThread?

  @@index([shopId, createdAt])
  @@index([phoneNormalized])
  @@index([disposition])
  @@index([riskScore])
}

enum Disposition {
  UNASSIGNED
  NEW
  CONFIRMED
  RESCHEDULED
  NO_ANSWER
  WRONG_NUMBER
  FAKE
  CANCELLED
  SHIPPED
  DELIVERED
  RETURNED
}

model OtpToken {
  id           String      @id @default(cuid())
  submissionId String?
  submission   Submission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  orderId      String?
  order        Order?      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  destination  String
  channel      OtpChannel
  code         String
  verifiedAt   DateTime?
  expiresAt    DateTime
  attempts     Int         @default(0)
  createdAt    DateTime    @default(now())

  @@index([submissionId])
  @@index([orderId])
}

enum OtpChannel {
  SMS
  WHATSAPP
  EMAIL
  VOICE
}

model Blocklist {
  id        String        @id @default(cuid())
  shopId    String?
  shop      Shop?         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  type      BlocklistType
  value     String
  valueHash String
  reason    String?
  expiresAt DateTime?
  createdAt DateTime      @default(now())

  @@unique([shopId, type, valueHash])
  @@index([valueHash, type])
}

enum BlocklistType {
  PHONE
  IP
  EMAIL
  POSTAL_CODE
  DEVICE
}

model Agent {
  id         String    @id @default(cuid())
  shopId     String
  shop       Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId     String
  name       String
  email      String?
  role       AgentRole @default(AGENT)
  isActive   Boolean   @default(true)
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  orders       Order[]
  agentActions AgentAction[]

  @@unique([shopId, userId])
}

enum AgentRole {
  OWNER
  MANAGER
  AGENT
  VIEWER
}

model AgentAction {
  id             String    @id @default(cuid())
  orderId        String
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  agentId        String
  agent          Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  actionType     String
  note           String?
  nextFollowUpAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([orderId, createdAt])
}

model CourierAccount {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  courier     String // postex | leopards | tcs | trax | mp | blueex | swyft | call | daewoo | aramex | shiprocket | dhl | custom
  label       String
  isActive    Boolean  @default(true)
  credentials Json     @default("{}")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings CourierBooking[]

  @@unique([shopId, courier])
}

model CourierBooking {
  id                String         @id @default(cuid())
  orderId           String
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courierAccountId  String
  courierAccount    CourierAccount @relation(fields: [courierAccountId], references: [id])
  consignmentNumber String?
  labelUrl          String?
  trackingUrl       String?
  status            String         @default("pending")
  trackingEvents    Json           @default("[]")
  bookedAt          DateTime?
  lastSyncedAt      DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([orderId])
  @@index([consignmentNumber])
}

model Message {
  id           String    @id @default(cuid())
  orderId      String
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  threadId     String?
  thread       InboxThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)
  channel      String // sms | whatsapp | email | voice
  direction    String // outbound | inbound
  templateId   String?
  provider     String?
  providerId   String?
  fromAddress  String?
  toAddress    String?
  body         String?
  payload      Json      @default("{}")
  status       String    @default("queued")
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failedAt     DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())

  @@index([orderId, createdAt])
  @@index([channel, status])
  @@index([threadId, createdAt])
}

model ABTest {
  id         String    @id @default(cuid())
  shopId     String
  shop       Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name       String    @default("")
  entityType String // form | upsell | button | headline
  entityId   String
  variants   Json      @default("[]") // [{ key, label, weight, schemaOverride? }]
  metric     String    @default("conversion_rate")
  status     String    @default("running") // running | stopped | completed
  winner     String?
  startedAt  DateTime  @default(now())
  endedAt    DateTime?

  exposures ABTestExposure[]

  @@index([shopId, entityType])
}

/// One row per (test, variant, day) aggregating views + conversions.
model ABTestExposure {
  id            String   @id @default(cuid())
  abTestId      String
  abTest        ABTest   @relation(fields: [abTestId], references: [id], onDelete: Cascade)
  variantKey    String
  bucketDate    DateTime @db.Date
  views         Int      @default(0)
  conversions   Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@unique([abTestId, variantKey, bucketDate])
  @@index([abTestId, bucketDate])
}

model WebhookSubscription {
  id             String    @id @default(cuid())
  shopId         String
  shop           Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  topic          String
  url            String
  secret         String
  isActive       Boolean   @default(true)
  lastDeliveryAt DateTime?
  lastStatusCode Int?
  failures       Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([shopId, topic])
}

// -----------------------------------------------------------------------------
// Phase 2 — Upsells, AI calls, abandoned recovery, ML risk history
// -----------------------------------------------------------------------------
model Upsell {
  id            String        @id @default(cuid())
  formId        String
  form          Form          @relation(fields: [formId], references: [id], onDelete: Cascade)
  name          String
  triggerType   UpsellTrigger @default(PRE_PURCHASE)
  triggerRule   Json          @default("{}") // optional conditional logic
  offerType     UpsellOffer   @default(DISCOUNT_PERCENT)
  productId     String?
  variantId     String?
  title         String
  description   String?
  imageUrl      String?
  discountType  String? // percent | flat
  discountValue Decimal?      @db.Decimal(10, 2)
  position      Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([formId, position])
}

enum UpsellTrigger {
  PRE_PURCHASE
  POST_PURCHASE
  ONE_TICK
}

enum UpsellOffer {
  DISCOUNT_PERCENT
  DISCOUNT_FLAT
  FREE_GIFT
  BUNDLE
  SHIPPING_PROTECTION
  GIFT_WRAP
}

model CallSession {
  id                 String    @id @default(cuid())
  orderId            String
  order              Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider           String // twilio | manual | elevenlabs-twilio
  providerId         String?
  direction          String    @default("outbound")
  status             String    @default("queued") // queued | dialing | answered | completed | failed | no_answer
  scriptId           String?
  language           String    @default("en")
  recordingUrl       String?
  transcript         String?
  durationSec        Int?
  dispositionCapture String?
  startedAt          DateTime?
  endedAt            DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([orderId, createdAt])
  @@index([status])
}

model AbandonedForm {
  id            String    @id @default(cuid())
  formId        String
  form          Form      @relation(fields: [formId], references: [id], onDelete: Cascade)
  visitorId     String
  phone         String?
  email         String?
  partialData   Json      @default("{}")
  lastStep      String?
  recoveryToken String    @unique
  notifiedAt    DateTime?
  convertedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([formId, createdAt])
  @@index([phone])
  @@index([email])
}

model RiskEvaluation {
  id           String   @id @default(cuid())
  orderId      String?
  order        Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  submissionId String?
  features     Json     @default("{}")
  score        Int
  label        String?
  model        String
  version      String
  createdAt    DateTime @default(now())

  @@index([orderId])
  @@index([submissionId])
}

model Pixel {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  provider    String // meta | tiktok | google | snapchat | pinterest
  pixelId     String
  accessToken String?
  capiEnabled Boolean  @default(false)
  testCode    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shopId, provider, pixelId])
}

// -----------------------------------------------------------------------------
// Phase 3 — moat features (fraud graph, RTO analytics, merchant groups, templates)
// -----------------------------------------------------------------------------

/// Cross-store shared blacklist network. Shops opt-in to report + consume entries.
/// `valueHash` is a SHA-256 of the normalized identifier so PII never leaves the shop.
model FraudGraphEntry {
  id           String   @id @default(cuid())
  type         BlocklistType
  valueHash    String
  reportCount  Int      @default(1)
  offenderHits Int      @default(0) // confirmed RTO / fake dispositions linked
  firstSeenAt  DateTime @default(now())
  lastSeenAt   DateTime @default(now())
  severity     Int      @default(1) // 1..5 — computed from reports/hits
  notes        String?

  reports FraudGraphReport[]

  @@unique([type, valueHash])
  @@index([valueHash])
  @@index([severity])
}

/// Per-shop report rows feeding into the fraud graph aggregates.
model FraudGraphReport {
  id              String   @id @default(cuid())
  entryId         String
  entry           FraudGraphEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  shopId          String
  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  reason          String
  disposition     String?
  linkedOrderId   String?
  createdAt       DateTime @default(now())

  @@index([entryId])
  @@index([shopId, createdAt])
}

/// Aggregated RTO metric per shop × dimension × bucket date.
/// `dimension` ∈ city | courier | product | sku | hour | day_of_week | country
model RtoStat {
  id           String   @id @default(cuid())
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  dimension    String
  dimensionKey String
  bucketDate   DateTime @db.Date
  totalOrders  Int      @default(0)
  rtoOrders    Int      @default(0)
  deliveredOrders Int   @default(0)
  confirmedOrders Int   @default(0)
  rtoRate      Decimal  @default(0) @db.Decimal(6, 4)
  updatedAt    DateTime @updatedAt

  @@unique([shopId, dimension, dimensionKey, bucketDate])
  @@index([shopId, dimension, bucketDate])
}

/// Multi-store ownership — one dashboard, many shops.
model MerchantGroup {
  id        String   @id @default(cuid())
  name      String
  ownerEmail String?
  plan      Plan     @default(PRO)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shops Shop[]

  @@index([ownerEmail])
}

/// Seed catalog of industry/region form templates ("marketplace").
model FormTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  category    String // apparel | electronics | food | services | pharmacy | other
  region      String? // PK | IN | MENA | GLOBAL
  language    String   @default("en")
  description String?
  schema      Json
  previewUrl  String?
  isFeatured  Boolean  @default(false)
  installCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([region])
}

// -----------------------------------------------------------------------------
// Phase 4 — WhatsApp inbox, payments, landing pages, GDPR
// -----------------------------------------------------------------------------

/// 2-way WhatsApp / SMS conversation thread. One per (shop, customer phone).
model InboxThread {
  id             String    @id @default(cuid())
  shopId         String
  shop           Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  channel        String    @default("whatsapp") // whatsapp | sms | email
  customerPhone  String?
  customerEmail  String?
  customerName   String?
  orderId        String?   @unique
  order          Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  lastMessageAt  DateTime  @default(now())
  lastDirection  String?
  lastPreview    String?
  unreadCount    Int       @default(0)
  status         String    @default("open") // open | resolved | snoozed
  assignedAgentId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  messages Message[]

  @@unique([shopId, channel, customerPhone])
  @@index([shopId, lastMessageAt])
  @@index([shopId, status])
}

/// Merchant-configured payment provider (JazzCash, EasyPaisa, SadaPay, Stripe,
/// Razorpay). One shop may have multiple entries (e.g. Jazz + SadaPay).
model PaymentProviderAccount {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  provider    String // jazzcash | easypaisa | sadapay | stripe | razorpay
  label       String
  credentials Json     @default("{}") // { apiKey, secret, merchantId, ... }
  mode        String   @default("mock") // mock | live
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  advances PaymentAdvance[]

  @@unique([shopId, provider, label])
  @@index([shopId])
}

/// Partial / split payment taken against an order (e.g. 20% advance).
model PaymentAdvance {
  id               String   @id @default(cuid())
  orderId          String
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  providerAccountId String
  providerAccount  PaymentProviderAccount @relation(fields: [providerAccountId], references: [id], onDelete: Restrict)
  amount           Decimal  @db.Decimal(14, 2)
  currency         String   @default("PKR")
  status           String   @default("pending") // pending | paid | failed | refunded | expired
  providerRef      String? // provider's transaction ID
  checkoutUrl      String?
  paidAt           DateTime?
  failedAt         DateTime?
  failureReason    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([orderId])
  @@index([status])
}

/// Custom landing page hosted by the app — used for ad campaigns that bypass
/// Shopify storefront entirely. Served at /f/:slug (shop-scoped or global).
model LandingPage {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  formId      String
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  slug        String   @unique
  title       String
  headline    String?
  subheadline String?
  heroImage   String?
  bodyHtml    String?
  theme       Json     @default("{}") // { accent, bgColor, logoUrl, direction }
  isPublished Boolean  @default(false)
  views       Int      @default(0)
  conversions Int      @default(0)
  utmDefault  Json     @default("{}") // { utm_source, utm_medium, utm_campaign }
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId])
  @@index([formId])
}

/// GDPR-compliance data export / deletion requests (Shopify customer webhooks).
model GdprExport {
  id         String   @id @default(cuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  kind       String // customer_data_request | customer_redact | shop_redact
  customerId String?
  payload    Json     @default("{}")
  status     String   @default("received") // received | processing | completed | failed
  processedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([shopId, kind])
  @@index([status])
}

// -----------------------------------------------------------------------------
// PR-B — Marketing sinks (Google Sheets, Klaviyo, Omnisend) + outbound webhook
// delivery log.
// -----------------------------------------------------------------------------

/// External marketing/data sink configured per shop. Credentials are JSON so
/// each provider can stash whatever keys it needs (api_key, sheet_id, refresh
/// token, etc). Settings is a separate field for non-secret config.
model Integration {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  provider    String // klaviyo | omnisend | google_sheets | mailchimp | sendgrid | custom
  label       String
  credentials Json     @default("{}")
  settings    Json     @default("{}")
  isActive    Boolean  @default(true)
  lastFiredAt DateTime?
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shopId, provider, label])
  @@index([shopId, provider])
}

/// One row per outbound webhook attempt (success or failure). Lets merchants
/// inspect their integration health and re-deliver failed events.
model WebhookDelivery {
  id              String   @id @default(cuid())
  shopId          String
  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  subscriptionId  String?
  topic           String
  url             String
  payload         Json
  statusCode      Int?
  responseBody    String?
  errorMessage    String?
  attempt         Int      @default(1)
  durationMs      Int?
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())

  @@index([shopId, createdAt])
  @@index([subscriptionId])
}

// -----------------------------------------------------------------------------
// PR-C — Discount codes + quantity offers + extended upsell types
// -----------------------------------------------------------------------------

/// Merchant-defined discount codes that customers can apply to their COD form
/// submission. Validated server-side before the draft order is created.
model Discount {
  id           String   @id @default(cuid())
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  code         String
  type         String // percent | flat | free_shipping
  value        Decimal  @default(0) @db.Decimal(10, 2)
  minSubtotal  Decimal? @db.Decimal(10, 2)
  appliesTo    String   @default("all") // all | products | collections
  productIds   Json     @default("[]")
  startsAt     DateTime?
  expiresAt    DateTime?
  usageLimit   Int?
  usageCount   Int      @default(0)
  perCustomer  Int?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  redemptions  DiscountRedemption[]

  @@unique([shopId, code])
  @@index([shopId, isActive])
}

/// Audit log of discount applications. One row per submission/order that used
/// a code. Powers per-customer limits and admin-side reporting.
model DiscountRedemption {
  id            String   @id @default(cuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  discountId    String
  discount      Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  submissionId  String?
  orderId       String?
  amount        Decimal  @default(0) @db.Decimal(10, 2)
  customerKey   String?  // hashed phone/email for per-customer cap
  createdAt     DateTime @default(now())

  @@index([discountId])
  @@index([shopId, createdAt])
}

/// Volume-discount ladder applied to a product or variant (or shop-wide). The
/// ladder is `[{ minQuantity, discountType, discountValue }]` evaluated at
/// submission time and persisted as part of the resulting line items.
model QuantityOffer {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String
  productId   String?  // when null, applies shop-wide
  variantId   String?
  ladder      Json     @default("[]") // [{ minQuantity:number, discountType:'percent'|'flat', discountValue:number }]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId, isActive])
  @@index([productId])
  @@index([variantId])
}
