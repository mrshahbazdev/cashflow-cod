// Cashflow COD — Prisma schema v1
// https://www.prisma.io/docs
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Shopify session storage (required by @shopify/shopify-app-session-storage-prisma)
// -----------------------------------------------------------------------------
model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)

  @@index([shop])
}

// -----------------------------------------------------------------------------
// Core app models
// -----------------------------------------------------------------------------
model Shop {
  id            String    @id @default(cuid())
  domain        String    @unique
  plan          Plan      @default(FREE)
  settings      Json      @default("{}")
  timezone      String    @default("UTC")
  installedAt   DateTime  @default(now())
  uninstalledAt DateTime?
  updatedAt     DateTime  @updatedAt

  merchantGroupId String?
  merchantGroup   MerchantGroup? @relation(fields: [merchantGroupId], references: [id], onDelete: SetNull)

  fraudGraphOptIn Boolean @default(false)

  forms           Form[]
  orders          Order[]
  blocklist       Blocklist[]
  agents          Agent[]
  pixels          Pixel[]
  webhooks        WebhookSubscription[]
  abTests         ABTest[]
  courierAccounts CourierAccount[]
  rtoStats        RtoStat[]
  fraudReports    FraudGraphReport[]

  @@index([domain])
  @@index([merchantGroupId])
}

enum Plan {
  FREE
  STARTER
  PRO
  SCALE
  ENTERPRISE
}

model Form {
  id        String     @id @default(cuid())
  shopId    String
  shop      Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  layout    FormLayout @default(POPUP)
  placement String     @default("product") // product | cart | landing | custom
  schema    Json       @default("{}") // form field definitions (Zod-validated JSON)
  isActive  Boolean    @default(true)
  abTestId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  submissions Submission[]
  orders      Order[]
  views       FormView[]
  upsells     Upsell[]
  abandoned   AbandonedForm[]

  @@unique([shopId, slug])
  @@index([shopId])
}

enum FormLayout {
  POPUP
  EMBEDDED
  SLIDEOVER
  LANDING
}

model FormView {
  id        String   @id @default(cuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  visitorId String
  ip        String?
  userAgent String?
  country   String?
  referrer  String?
  createdAt DateTime @default(now())

  @@index([formId, createdAt])
}

model Submission {
  id              String           @id @default(cuid())
  formId          String
  form            Form             @relation(fields: [formId], references: [id], onDelete: Cascade)
  visitorId       String
  status          SubmissionStatus @default(PENDING)
  fields          Json             @default("{}")
  fieldsEncrypted Bytes?
  phone           String?
  email           String?
  ipAddress       String?
  userAgent       String?
  country         String?
  riskScore       Int?
  riskReasons     Json             @default("[]")
  requiresOtp     Boolean          @default(false)
  abVariant       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  order     Order?
  otpTokens OtpToken[]

  @@index([formId, createdAt])
  @@index([status])
}

enum SubmissionStatus {
  PENDING
  VERIFIED
  REJECTED
  CONVERTED
  ABANDONED
}

model Order {
  id              String      @id @default(cuid())
  shopId          String
  shop            Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopifyOrderId  String?     @unique
  shopifyOrderGid String?
  submissionId    String?     @unique
  submission      Submission? @relation(fields: [submissionId], references: [id])
  formId          String?
  form            Form?       @relation(fields: [formId], references: [id])
  phone           String?
  phoneNormalized String?
  email           String?
  customerName    String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  region          String?
  postalCode      String?
  country         String?
  lineItems       Json        @default("[]")
  upsells         Json        @default("[]")
  subtotal        Decimal?    @db.Decimal(14, 2)
  codFee          Decimal?    @db.Decimal(14, 2)
  discount        Decimal?    @db.Decimal(14, 2)
  total           Decimal?    @db.Decimal(14, 2)
  currency        String?
  riskScore       Int?
  riskReasons     Json        @default("[]")
  disposition     Disposition @default(UNASSIGNED)
  agentId         String?
  agent           Agent?      @relation(fields: [agentId], references: [id])
  attempts        Int         @default(0)
  nextFollowUpAt  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  otps            OtpToken[]
  messages        Message[]
  agentActions    AgentAction[]
  courierBookings CourierBooking[]
  callSessions    CallSession[]
  riskEvaluations RiskEvaluation[]

  @@index([shopId, createdAt])
  @@index([phoneNormalized])
  @@index([disposition])
  @@index([riskScore])
}

enum Disposition {
  UNASSIGNED
  NEW
  CONFIRMED
  RESCHEDULED
  NO_ANSWER
  WRONG_NUMBER
  FAKE
  CANCELLED
  SHIPPED
  DELIVERED
  RETURNED
}

model OtpToken {
  id           String      @id @default(cuid())
  submissionId String?
  submission   Submission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  orderId      String?
  order        Order?      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  destination  String
  channel      OtpChannel
  code         String
  verifiedAt   DateTime?
  expiresAt    DateTime
  attempts     Int         @default(0)
  createdAt    DateTime    @default(now())

  @@index([submissionId])
  @@index([orderId])
}

enum OtpChannel {
  SMS
  WHATSAPP
  EMAIL
  VOICE
}

model Blocklist {
  id        String        @id @default(cuid())
  shopId    String?
  shop      Shop?         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  type      BlocklistType
  value     String
  valueHash String
  reason    String?
  expiresAt DateTime?
  createdAt DateTime      @default(now())

  @@unique([shopId, type, valueHash])
  @@index([valueHash, type])
}

enum BlocklistType {
  PHONE
  IP
  EMAIL
  POSTAL_CODE
  DEVICE
}

model Agent {
  id         String    @id @default(cuid())
  shopId     String
  shop       Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId     String
  name       String
  email      String?
  role       AgentRole @default(AGENT)
  isActive   Boolean   @default(true)
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  orders       Order[]
  agentActions AgentAction[]

  @@unique([shopId, userId])
}

enum AgentRole {
  OWNER
  MANAGER
  AGENT
  VIEWER
}

model AgentAction {
  id             String    @id @default(cuid())
  orderId        String
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  agentId        String
  agent          Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  actionType     String
  note           String?
  nextFollowUpAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([orderId, createdAt])
}

model CourierAccount {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  courier     String // postex | leopards | tcs | trax | mp | blueex | swyft | call | daewoo | aramex | shiprocket | dhl | custom
  label       String
  isActive    Boolean  @default(true)
  credentials Json     @default("{}")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings CourierBooking[]

  @@unique([shopId, courier])
}

model CourierBooking {
  id                String         @id @default(cuid())
  orderId           String
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courierAccountId  String
  courierAccount    CourierAccount @relation(fields: [courierAccountId], references: [id])
  consignmentNumber String?
  labelUrl          String?
  trackingUrl       String?
  status            String         @default("pending")
  trackingEvents    Json           @default("[]")
  bookedAt          DateTime?
  lastSyncedAt      DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([orderId])
  @@index([consignmentNumber])
}

model Message {
  id           String    @id @default(cuid())
  orderId      String
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  channel      String // sms | whatsapp | email | voice
  direction    String // outbound | inbound
  templateId   String?
  provider     String?
  providerId   String?
  payload      Json      @default("{}")
  status       String    @default("queued")
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failedAt     DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())

  @@index([orderId, createdAt])
  @@index([channel, status])
}

model ABTest {
  id         String    @id @default(cuid())
  shopId     String
  shop       Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  entityType String // form | upsell | button | headline
  entityId   String
  variants   Json      @default("[]")
  metric     String    @default("conversion_rate")
  winner     String?
  startedAt  DateTime  @default(now())
  endedAt    DateTime?

  @@index([shopId, entityType])
}

model WebhookSubscription {
  id             String    @id @default(cuid())
  shopId         String
  shop           Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  topic          String
  url            String
  secret         String
  isActive       Boolean   @default(true)
  lastDeliveryAt DateTime?
  lastStatusCode Int?
  failures       Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([shopId, topic])
}

// -----------------------------------------------------------------------------
// Phase 2 — Upsells, AI calls, abandoned recovery, ML risk history
// -----------------------------------------------------------------------------
model Upsell {
  id            String        @id @default(cuid())
  formId        String
  form          Form          @relation(fields: [formId], references: [id], onDelete: Cascade)
  name          String
  triggerType   UpsellTrigger @default(PRE_PURCHASE)
  triggerRule   Json          @default("{}") // optional conditional logic
  offerType     UpsellOffer   @default(DISCOUNT_PERCENT)
  productId     String?
  variantId     String?
  title         String
  description   String?
  imageUrl      String?
  discountType  String? // percent | flat
  discountValue Decimal?      @db.Decimal(10, 2)
  position      Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([formId, position])
}

enum UpsellTrigger {
  PRE_PURCHASE
  POST_PURCHASE
  ONE_TICK
}

enum UpsellOffer {
  DISCOUNT_PERCENT
  DISCOUNT_FLAT
  FREE_GIFT
  BUNDLE
}

model CallSession {
  id                 String    @id @default(cuid())
  orderId            String
  order              Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider           String // twilio | manual | elevenlabs-twilio
  providerId         String?
  direction          String    @default("outbound")
  status             String    @default("queued") // queued | dialing | answered | completed | failed | no_answer
  scriptId           String?
  language           String    @default("en")
  recordingUrl       String?
  transcript         String?
  durationSec        Int?
  dispositionCapture String?
  startedAt          DateTime?
  endedAt            DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([orderId, createdAt])
  @@index([status])
}

model AbandonedForm {
  id            String    @id @default(cuid())
  formId        String
  form          Form      @relation(fields: [formId], references: [id], onDelete: Cascade)
  visitorId     String
  phone         String?
  email         String?
  partialData   Json      @default("{}")
  lastStep      String?
  recoveryToken String    @unique
  notifiedAt    DateTime?
  convertedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([formId, createdAt])
  @@index([phone])
  @@index([email])
}

model RiskEvaluation {
  id           String   @id @default(cuid())
  orderId      String?
  order        Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  submissionId String?
  features     Json     @default("{}")
  score        Int
  label        String?
  model        String
  version      String
  createdAt    DateTime @default(now())

  @@index([orderId])
  @@index([submissionId])
}

model Pixel {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  provider    String // meta | tiktok | google | snapchat | pinterest
  pixelId     String
  accessToken String?
  capiEnabled Boolean  @default(false)
  testCode    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shopId, provider, pixelId])
}

// -----------------------------------------------------------------------------
// Phase 3 — moat features (fraud graph, RTO analytics, merchant groups, templates)
// -----------------------------------------------------------------------------

/// Cross-store shared blacklist network. Shops opt-in to report + consume entries.
/// `valueHash` is a SHA-256 of the normalized identifier so PII never leaves the shop.
model FraudGraphEntry {
  id           String   @id @default(cuid())
  type         BlocklistType
  valueHash    String
  reportCount  Int      @default(1)
  offenderHits Int      @default(0) // confirmed RTO / fake dispositions linked
  firstSeenAt  DateTime @default(now())
  lastSeenAt   DateTime @default(now())
  severity     Int      @default(1) // 1..5 — computed from reports/hits
  notes        String?

  reports FraudGraphReport[]

  @@unique([type, valueHash])
  @@index([valueHash])
  @@index([severity])
}

/// Per-shop report rows feeding into the fraud graph aggregates.
model FraudGraphReport {
  id              String   @id @default(cuid())
  entryId         String
  entry           FraudGraphEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  shopId          String
  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  reason          String
  disposition     String?
  linkedOrderId   String?
  createdAt       DateTime @default(now())

  @@index([entryId])
  @@index([shopId, createdAt])
}

/// Aggregated RTO metric per shop × dimension × bucket date.
/// `dimension` ∈ city | courier | product | sku | hour | day_of_week | country
model RtoStat {
  id           String   @id @default(cuid())
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  dimension    String
  dimensionKey String
  bucketDate   DateTime @db.Date
  totalOrders  Int      @default(0)
  rtoOrders    Int      @default(0)
  deliveredOrders Int   @default(0)
  confirmedOrders Int   @default(0)
  rtoRate      Decimal  @default(0) @db.Decimal(6, 4)
  updatedAt    DateTime @updatedAt

  @@unique([shopId, dimension, dimensionKey, bucketDate])
  @@index([shopId, dimension, bucketDate])
}

/// Multi-store ownership — one dashboard, many shops.
model MerchantGroup {
  id        String   @id @default(cuid())
  name      String
  ownerEmail String?
  plan      Plan     @default(PRO)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shops Shop[]

  @@index([ownerEmail])
}

/// Seed catalog of industry/region form templates ("marketplace").
model FormTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  category    String // apparel | electronics | food | services | pharmacy | other
  region      String? // PK | IN | MENA | GLOBAL
  language    String   @default("en")
  description String?
  schema      Json
  previewUrl  String?
  isFeatured  Boolean  @default(false)
  installCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([region])
}
