{
  "name": "@cashflow-cod/admin",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Cashflow COD — Shopify embedded merchant admin app (Remix + Polaris)",
  "scripts": {
    "build": "remix vite:build",
    "dev": "shopify app dev",
    "config:link": "shopify app config link",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "deploy": "shopify app deploy",
    "generate": "shopify app generate",
    "start": "remix-serve ./build/server/index.js",
    "docker-start": "pnpm db:migrate && pnpm start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --ext .js,.ts,.jsx,.tsx ./app",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "setup": "pnpm db:generate && pnpm db:push"
  },
  "dependencies": {
    "@cashflow-cod/couriers": "workspace:*",
    "@cashflow-cod/form-schema": "workspace:*",
    "@cashflow-cod/messaging": "workspace:*",
    "@cashflow-cod/payments": "workspace:*",
    "@cashflow-cod/shared-types": "workspace:*",
    "@hello-pangea/dnd": "^18.0.1",
    "@prisma/client": "^6.2.1",
    "@remix-run/dev": "^2.15.2",
    "@remix-run/node": "^2.15.2",
    "@remix-run/react": "^2.15.2",
    "@remix-run/serve": "^2.15.2",
    "@shopify/app-bridge-react": "^4.1.6",
    "@shopify/polaris": "^13.9.5",
    "@shopify/shopify-app-remix": "^3.5.1",
    "@shopify/shopify-app-session-storage-prisma": "^6.0.1",
    "isbot": "^5.1.19",
    "nanoid": "^5.1.9",
    "prisma": "^6.2.1",
    "zod": "^3.23.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@remix-run/eslint-config": "^2.15.2",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
