{
  "extends": "../../tsconfig.base.json",
  "include": [
    "env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/.server/**/*.ts",
    "**/.server/**/*.tsx",
    "**/.client/**/*.ts",
    "**/.client/**/*.tsx"
  ],
  "exclude": [
    "extensions/checkout-cod-fee/**",
    "extensions/cod-form-embed/**",
    "extensions/cod-fee-discount/**",
    "extensions/cod-delivery-customization/**",
    "extensions/cod-payment-customization/**"
  ],
  "compilerOptions": {
    "types": ["@remix-run/node", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"]
    },
    "noEmit": true
  }
}
