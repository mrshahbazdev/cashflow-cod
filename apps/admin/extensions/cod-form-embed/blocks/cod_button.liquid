{% comment %}
  Cashflow COD — Button block
  Drop-in CTA that opens any published COD form. Unlike the embed block
  (which boots at <body>), this one is a section block so merchants can
  drag it into any section in the theme editor (product page, custom
  landing, blog post, etc).
{% endcomment %}

<div
  class="cashflow-cod-root"
  data-cashflow-cod-root
  data-shop="{{ shop.permanent_domain }}"
  data-form-slug="{{ block.settings.form_slug }}"
  data-placement="custom"
  data-trigger="button"
  data-accent="{{ block.settings.accent_color }}"
  data-language="{{ block.settings.language }}"
  data-api="{{ block.settings.api_origin }}"
  data-product-id="{% if product %}{{ product.id }}{% endif %}"
  data-variant-id="{% if product %}{{ product.selected_or_first_available_variant.id }}{% endif %}"
  style="text-align:{{ block.settings.alignment }};"
>
  <button
    type="button"
    class="cashflow-cod-trigger"
    data-cashflow-cod-trigger
    style="background:{{ block.settings.accent_color }};"
  >
    {{ block.settings.button_label }}
  </button>
</div>

{{ 'cod-form.css' | asset_url | stylesheet_tag }}
<script src="{{ 'cod-form.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Cashflow COD Button",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "api_origin",
      "label": "API origin",
      "default": "https://your-cashflow-cod-app.example",
      "info": "Public URL of your Cashflow COD admin app."
    },
    {
      "type": "text",
      "id": "form_slug",
      "label": "Form slug",
      "default": "default",
      "info": "The slug of the form to open."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Buy with Cash on Delivery"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#008060"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "language",
      "label": "Language",
      "options": [
        { "value": "auto", "label": "Auto (detect)" },
        { "value": "en", "label": "English" },
        { "value": "ur", "label": "Urdu" },
        { "value": "ar", "label": "Arabic" },
        { "value": "hi", "label": "Hindi" },
        { "value": "bn", "label": "Bengali" },
        { "value": "id", "label": "Indonesian" }
      ],
      "default": "auto"
    }
  ]
}
{% endschema %}
