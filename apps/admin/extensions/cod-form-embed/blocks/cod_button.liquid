{% comment %}
  Cashflow COD — Button block (target: section)
  Drop-in CTA that opens any published COD form. Section-level so it can
  be dragged into any theme section in the editor.
{% endcomment %}

{% liquid
  assign cf_api = block.settings.api_origin | default: 'https://cashflow-cod-production-2aff.up.railway.app'
  assign cf_slug = block.settings.form_slug | default: 'default'
  assign cf_label = block.settings.button_label | default: 'Buy with Cash on Delivery'
  assign cf_radius = block.settings.button_radius | default: 10
  assign cf_font_size = block.settings.font_size | default: 16
  assign cf_pad_x = block.settings.padding_x | default: 22
  assign cf_pad_y = block.settings.padding_y | default: 14
  assign cf_full_width = block.settings.full_width | default: false
  assign cf_icon = block.settings.icon | default: 'none'
  assign cf_align = block.settings.alignment | default: 'center'
  assign cf_accent = block.settings.accent_color | default: '#008060'
  assign cf_text_color = block.settings.text_color | default: '#ffffff'
%}

<style>
  .cashflow-cod-cta-{{ block.id }} {
    display: {% if cf_full_width %}block{% else %}inline-flex{% endif %};
    {% if cf_full_width %}width: 100%;{% endif %}
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: {{ cf_pad_y }}px {{ cf_pad_x }}px;
    font-size: {{ cf_font_size }}px;
    font-weight: 600;
    color: {{ cf_text_color }};
    background: {{ cf_accent }};
    border: none;
    border-radius: {{ cf_radius }}px;
    cursor: pointer;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      filter 0.18s ease;
  }
  .cashflow-cod-cta-{{ block.id }}:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.14);
    filter: brightness(1.04);
  }
  .cashflow-cod-cta-{{ block.id }}:active {
    transform: translateY(0);
    filter: brightness(0.96);
  }
  .cashflow-cod-cta-{{ block.id }} svg {
    width: {{ cf_font_size | plus: 2 }}px;
    height: {{ cf_font_size | plus: 2 }}px;
    flex: 0 0 auto;
  }
</style>

<div
  class="cashflow-cod-root"
  data-cashflow-cod-root
  data-shop="{{ shop.permanent_domain }}"
  data-form-slug="{{ cf_slug }}"
  data-placement="custom"
  data-trigger="button"
  data-accent="{{ cf_accent }}"
  data-language="{{ block.settings.language }}"
  data-api="{{ cf_api }}"
  data-product-id="{% if product %}{{ product.id }}{% endif %}"
  data-variant-id="{% if product %}{{ product.selected_or_first_available_variant.id }}{% endif %}"
  style="text-align:{{ cf_align }};{% if cf_full_width %}display:block;{% endif %}"
>
  <button type="button" class="cashflow-cod-cta-{{ block.id }} cashflow-cod-trigger" data-cashflow-cod-trigger>
    {%- case cf_icon -%}
      {%- when 'cart' -%}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/></svg>
      {%- when 'lock' -%}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      {%- when 'truck' -%}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7"/><circle cx="6" cy="19" r="2"/><circle cx="19" cy="19" r="2"/></svg>
      {%- when 'whatsapp' -%}
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.05 4.91A10.43 10.43 0 0 0 12 2a10.5 10.5 0 0 0-9.06 15.7L2 22l4.5-1.18A10.5 10.5 0 1 0 19.05 4.91zM12 20.13a8.6 8.6 0 0 1-4.4-1.2l-.31-.18-2.67.7.71-2.6-.2-.32a8.63 8.63 0 1 1 6.87 3.6zm4.95-6.45c-.27-.13-1.6-.79-1.85-.88s-.43-.13-.61.13-.7.88-.86 1.06-.32.2-.59.07a7.05 7.05 0 0 1-2.07-1.28 7.83 7.83 0 0 1-1.43-1.78c-.15-.27 0-.41.12-.54s.27-.32.4-.48a1.86 1.86 0 0 0 .27-.45.5.5 0 0 0 0-.47c-.07-.13-.61-1.46-.83-2s-.45-.45-.61-.46h-.52a1 1 0 0 0-.72.34 3 3 0 0 0-.95 2.24 5.22 5.22 0 0 0 1.1 2.78 12 12 0 0 0 4.6 4.07c.65.28 1.16.45 1.55.58a3.74 3.74 0 0 0 1.71.11 2.78 2.78 0 0 0 1.83-1.29 2.27 2.27 0 0 0 .16-1.29c-.07-.12-.24-.2-.5-.32z"/></svg>
      {%- when 'phone' -%}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
    {%- endcase -%}
    <span>{{ cf_label }}</span>
  </button>
</div>

{{ 'cod-form.css' | asset_url | stylesheet_tag }}
<script src="{{ 'cod-form.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Cashflow COD Button",
  "target": "section",
  "settings": [
    {
      "type": "header",
      "content": "Form"
    },
    {
      "type": "text",
      "id": "form_slug",
      "label": "Form slug",
      "default": "default",
      "info": "Leave as 'default' to use your default COD form, or paste another form slug from /app/forms."
    },
    {
      "type": "select",
      "id": "language",
      "label": "Language",
      "options": [
        { "value": "auto", "label": "Auto (detect)" },
        { "value": "en", "label": "English" },
        { "value": "ur", "label": "Urdu" },
        { "value": "ar", "label": "Arabic" },
        { "value": "hi", "label": "Hindi" },
        { "value": "bn", "label": "Bengali" },
        { "value": "id", "label": "Indonesian" }
      ],
      "default": "auto"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Buy with Cash on Delivery"
    },
    {
      "type": "select",
      "id": "icon",
      "label": "Icon",
      "options": [
        { "value": "none", "label": "No icon" },
        { "value": "cart", "label": "Shopping cart" },
        { "value": "lock", "label": "Lock (secure)" },
        { "value": "truck", "label": "Delivery truck" },
        { "value": "whatsapp", "label": "WhatsApp" },
        { "value": "phone", "label": "Phone" }
      ],
      "default": "cart"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Background color",
      "default": "#008060"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 6,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal padding",
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "header",
      "content": "Advanced"
    },
    {
      "type": "text",
      "id": "api_origin",
      "label": "API origin (override)",
      "default": "https://cashflow-cod-production-2aff.up.railway.app",
      "info": "Default points at the official Cashflow COD app. Only change if you self-host on a custom domain."
    }
  ]
}
{% endschema %}
