{% comment %}
  Cashflow COD — App Embed Block
  Injects the COD order form on product pages, cart pages, or custom
  landing pages. Merchants enable this block in the theme editor under
  "Apps".
{% endcomment %}

<div
  id="cashflow-cod-root"
  data-shop="{{ shop.permanent_domain }}"
  data-form-slug="{{ block.settings.form_slug }}"
  data-placement="{{ block.settings.placement }}"
  data-trigger="{{ block.settings.trigger }}"
  data-accent="{{ block.settings.accent_color }}"
  data-language="{{ block.settings.language }}"
  data-product-id="{% if product %}{{ product.id }}{% endif %}"
  data-variant-id="{% if product %}{{ product.selected_or_first_available_variant.id }}{% endif %}"
>
  {% if block.settings.trigger == 'button' %}
    <button
      type="button"
      class="cashflow-cod-trigger"
      data-cashflow-cod-trigger
      style="background:{{ block.settings.accent_color }};"
    >
      {{ block.settings.button_label }}
    </button>
  {% endif %}
</div>

{{ 'cod-form.css' | asset_url | stylesheet_tag }}
<script src="{{ 'cod-form.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Cashflow COD Form",
  "target": "body",
  "javascript": "cod-form.js",
  "stylesheet": "cod-form.css",
  "settings": [
    {
      "type": "header",
      "content": "Form"
    },
    {
      "type": "text",
      "id": "form_slug",
      "label": "Form slug",
      "default": "default",
      "info": "The slug of the form you configured in the Cashflow COD admin."
    },
    {
      "type": "select",
      "id": "placement",
      "label": "Placement",
      "options": [
        { "value": "product", "label": "Product page" },
        { "value": "cart", "label": "Cart page" },
        { "value": "landing", "label": "Dedicated landing page" }
      ],
      "default": "product"
    },
    {
      "type": "select",
      "id": "trigger",
      "label": "Trigger",
      "options": [
        { "value": "button", "label": "Button (opens popup)" },
        { "value": "inline", "label": "Inline embed" },
        { "value": "floating", "label": "Floating button" }
      ],
      "default": "button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Buy with Cash on Delivery"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#008060"
    },
    {
      "type": "select",
      "id": "language",
      "label": "Language",
      "options": [
        { "value": "auto", "label": "Auto (detect)" },
        { "value": "en", "label": "English" },
        { "value": "ur", "label": "Urdu" },
        { "value": "ar", "label": "Arabic" },
        { "value": "hi", "label": "Hindi" },
        { "value": "bn", "label": "Bengali" },
        { "value": "id", "label": "Indonesian" }
      ],
      "default": "auto"
    }
  ]
}
{% endschema %}
