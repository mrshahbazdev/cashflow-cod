# Shopify app credentials (from https://partners.shopify.com)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://your-tunnel.example.com
SCOPES=read_products,write_products,read_orders,write_orders,read_customers,write_customers,write_draft_orders,read_themes

# Database
DATABASE_URL=postgresql://cashflow:cashflow@localhost:5432/cashflow_cod?schema=public

# Redis (cache + BullMQ queues)
REDIS_URL=redis://localhost:6379

# Session encryption
SESSION_SECRET=replace-with-32-char-random-string

# Field-level PII encryption (AES-256-GCM key, base64 encoded)
PII_ENCRYPTION_KEY=

# Messaging providers (optional in dev)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WA_FROM=

# WhatsApp Business (360Dialog / Gupshup) - optional
WHATSAPP_PROVIDER=twilio
WHATSAPP_API_KEY=
WHATSAPP_API_URL=

# ML service (RTO risk scoring)
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_API_KEY=dev-local-key

# ClickHouse (analytics events) - optional in dev
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Node
NODE_ENV=development
LOG_LEVEL=debug
